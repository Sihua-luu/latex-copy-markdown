{
  "manifest_version": 3,
  "name": "LaTeX Copy Markdown",
  "version": "2.1",
  "description": "Click on LaTeX math formulas to copy their Markdown source ($...$ or $$...$$).",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["page-script.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
